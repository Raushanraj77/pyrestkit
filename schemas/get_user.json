        "email",
        "first_name",
        "last_name"
    ],
    "properties": {
        "id": {
            "type": "integer"
        },
        "email": {
            "type": "string"
        },
        "first_name": {
            "type": "string"
        },
        "last_name": {
            "type": "string"
        }
    }
}